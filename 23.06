      likes: 245,
      technologies: ["React", "Node.js", "MongoDB", "CSS"]
    },
    {
      id: 2,
      title: "Логотип для стартапа",
      category: "Дизайн",
      likes: 89,
      technologies: ["Figma", "Illustrator", "Photoshop"]
    },
    {
      id: 3,
      title: "Микросервис авторизации",
      category: "Бекенд",
      likes: 134,
      technologies: ["Go", "PostgreSQL", "gRPC", "Docker"]
    },
    {
      id: 4,
      title: "Интернет-магазин одежды",
      category: "Веб",
