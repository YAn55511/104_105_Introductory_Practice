const profileKeys = Object.keys(portfolioData.profile);
console.log("Ключи профиля:", profileKeys);

const popularProjects = portfolioData.projects.filter(
  project => project.likes > 100
);

const popularProjectsStrings = popularProjects.map(
  project => `Проект: ${project.title} из категории ${project.category}`
);

console.log("Популярные проекты (>100 лайков):", popularProjectsStrings);

let totalLikes = 0;

portfolioData.projects.forEach(project => {
  totalLikes += project.likes;
});

console.log(`Общее число лайков: ${totalLikes}`);

const techSet = new Set();

portfolioData.projects.forEach(project => {
  project.technologies.forEach(tech => {
    techSet.add(tech);
  });
});

console.log("Уникальные технологии (Set):", techSet);
console.log("Уникальные технологии (массив):", Array.from(techSet));
