<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Визитка</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Roboto, system-ui, sans-serif;
      background: #f0f2f5;
      color: #1e293b;
      overflow-x: hidden;
      min-height: 100vh;
    }

    .app {
      display: flex;
      max-width: 1400px;
      width: 95%;
      margin: 2rem auto;
      gap: 2rem;
      align-items: flex-start;
    }

    .sidebar {
      background: #ffffff;
      border-radius: 24px;
      padding: 2rem 1.5rem;
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
      display: flex;
      flex-direction: column;
      gap: 2rem;
      flex: 0 0 280px;
      min-width: 0;
      position: sticky;
      top: 2rem;
    }

    .profile-card {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .avatar {
      width: 70px;
      height: 70px;
      border-radius: 50%;
      overflow: hidden;
      flex-shrink: 0;
      border: 3px solid #e2e8f0;
    }

    .avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .profile-card h2 {
      font-size: 1.3rem;
      font-weight: 700;
      line-height: 1.2;
    }

    .role {
      font-size: 0.85rem;
      color: #64748b;
      background: #f1f5f9;
      display: inline-block;
      padding: 0.15rem 0.8rem;
      border-radius: 50px;
      margin-top: 0.2rem;
    }

    .nav-menu {
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
    }

    .nav-logo {
      font-size: 1.8rem;
    }

    .nav-links {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .nav-links a {
      text-decoration: none;
      color: #475569;
      font-weight: 500;
      padding: 0.5rem 1rem;
      border-radius: 12px;
      transition: all 0.2s;
      display: block;
    }

    .nav-links a:hover {
      background: #f1f5f9;
      color: #2563eb;
    }

    .skills-block {
      background: #f8fafc;
      padding: 1rem;
      border-radius: 16px;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .badge {
      font-weight: 600;
      font-size: 0.9rem;
      color: #0f172a;
    }

    .skills-block span:not(.badge) {
      color: #475569;
      font-size: 0.9rem;
    }

    main {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .projects-section {
      background: #ffffff;
      border-radius: 24px;
      padding: 2rem;
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
    }

    .projects-section h2 {
      font-size: 1.8rem;
      font-weight: 700;
      margin-bottom: 1.5rem;
    }

    .projects-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }

    .project-card {
      background: #f8fafc;
      border-radius: 16px;
      padding: 1.5rem 1.2rem;
      transition: transform 0.15s, box-shadow 0.15s;
      border: 1px solid #eef2f6;
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }

    .project-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.06);
    }

    .project-icon {
      font-size: 2.2rem;
      margin-bottom: 0.3rem;
    }

    .project-card h3 {
      font-size: 1.1rem;
      font-weight: 600;
    }

    .project-card p {
      color: #64748b;
      font-size: 0.9rem;
    }

    .project-tag {
      background: #e2e8f0;
      color: #334155;
      font-size: 0.75rem;
      font-weight: 600;
      padding: 0.2rem 0.8rem;
      border-radius: 50px;
      align-self: flex-start;
      margin-top: 0.3rem;
    }

    .contact-block {
      background: #ffffff;
      border-radius: 24px;
      padding: 1.5rem 2rem;
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
      display: flex;
      align-items: center;
      gap: 2rem;
      flex-wrap: wrap;
    }

    .label {
      font-weight: 600;
      color: #0f172a;
      font-size: 1rem;
    }

    .chips {
      display: flex;
      gap: 0.8rem;
      flex-wrap: wrap;
    }

    .chips span {
      background: #f1f5f9;
      padding: 0.3rem 1.2rem;
      border-radius: 50px;
      font-size: 0.9rem;
      color: #334155;
      font-weight: 500;
    }

    .status {
      background: #22c55e;
      color: #fff;
      padding: 0.2rem 1.2rem;
      border-radius: 50px;
      font-size: 0.8rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-left: auto;
    }

    @media (max-width: 1200px) {
      .projects-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (max-width: 992px) {
      .app {
        flex-direction: column;
      }

      .sidebar {
        flex: none;
        width: 100%;
        position: static;
        flex-direction: row;
        flex-wrap: wrap;
        align-items: center;
        gap: 1.5rem;
        padding: 1.5rem;
      }

      .profile-card {
        flex: 0 1 auto;
      }

      .nav-menu {
        flex-direction: row;
        align-items: center;
        gap: 1rem;
        flex: 1;
      }

      .nav-links {
        flex-direction: row;
        gap: 0.5rem;
      }

      .skills-block {
        flex: 1;
        min-width: 150px;
      }

      .projects-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (max-width: 768px) {
      .app {
        width: 92%;
        margin: 1rem auto;
        gap: 1.5rem;
      }

      .projects-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
      }

      .projects-section {
        padding: 1.5rem;
      }

      .projects-section h2 {
        font-size: 1.5rem;
      }

      .sidebar {
        flex-direction: column;
        align-items: stretch;
        padding: 1.5rem;
        gap: 1.5rem;
      }

      .profile-card {
        justify-content: center;
      }

      .nav-menu {
        flex-direction: column;
        align-items: stretch;
      }

      .nav-links {
        flex-direction: column;
        gap: 0.3rem;
      }

      .nav-links a {
        text-align: center;
        padding: 0.6rem;
      }

      .skills-block {
        align-items: center;
        text-align: center;
      }

      .contact-block {
        flex-direction: column;
        align-items: center;
        gap: 0.8rem;
        padding: 1.5rem;
      }

      .status {
        margin-left: 0;
      }

      .chips {
        justify-content: center;
      }
    }

    @media (max-width: 480px) {
      .app {
        width: 96%;
        margin: 0.5rem auto;
        gap: 1rem;
      }

      .projects-grid {
        grid-template-columns: 1fr;
        gap: 0.8rem;
      }

      .projects-section {
        padding: 1rem;
      }

      .projects-section h2 {
        font-size: 1.3rem;
        text-align: center;
      }

      .sidebar {
        padding: 1rem;
        border-radius: 16px;
        gap: 1rem;
      }

      .profile-card {
        flex-direction: column;
        text-align: center;
        gap: 0.5rem;
      }

      .avatar {
        width: 80px;
        height: 80px;
      }

      .profile-card h2 {
        font-size: 1.2rem;
      }

      .nav-links a {
        font-size: 0.95rem;
        padding: 0.7rem;
      }

      .skills-block span:not(.badge) {
        font-size: 0.85rem;
      }

      .contact-block {
        padding: 1rem;
        gap: 0.6rem;
      }

      .label {
        font-size: 0.9rem;
      }

      .chips span {
        font-size: 0.8rem;
        padding: 0.2rem 1rem;
      }

      .status {
        font-size: 0.7rem;
        padding: 0.15rem 1rem;
      }

      .project-card {
        padding: 1rem;
        align-items: center;
        text-align: center;
      }

      .project-tag {
        align-self: center;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <aside class="sidebar">
      <div class="profile-card">
        <div class="avatar">
          <img src="https://p.mrsu.ru/Data/imj-content/1/8/18d34e5c-1d7d-4597-97f5-1964fa0e8fe6/photo/1-5372d962-fc83-4758-9e89-df3824bf14d0.jpg" alt="Аватар">
        </div>
        <div>
          <h2>Ян Кулыгин</h2>
          <div class="role">Ухiлянт</div>
        </div>
      </div>

      <nav class="nav-menu">
        <span class="nav-logo">⚡</span>
        <ul class="nav-links">
          <li><a href="#">Проекты</a></li>
          <li><a href="#">Опыт</a></li>
          <li><a href="#">Контакты</a></li>
        </ul>
      </nav>

      <div class="skills-block">
        <span class="badge">🔥 Навыки</span>
        <span>React · CSS · Figma</span>
        <span>+8</span>
      </div>
    </aside>

    <main>
      <section class="projects-section">
        <h2>🛠️ Мои проекты</h2>
        <div class="projects-grid">
          <div class="project-card">
            <div class="project-icon">📊</div>
            <h3>Dashboard</h3>
            <p>Аналитика и графики</p>
            <span class="project-tag">React</span>
          </div>
          <div class="project-card">
            <div class="project-icon">🎨</div>
            <h3>UI Kit</h3>
            <p>Система дизайна</p>
            <span class="project-tag">Figma</span>
          </div>
          <div class="project-card">
            <div class="project-icon">📱</div>
            <h3>Mobile App</h3>
            <p>Кроссплатформа</p>
            <span class="project-tag">Flutter</span>
          </div>
          <div class="project-card">
            <div class="project-icon">⚡</div>
            <h3>Landing</h3>
            <p>Высокая скорость</p>
            <span class="project-tag">Astro</span>
          </div>
          <div class="project-card">
            <div class="project-icon">🛒</div>
            <h3>E‑commerce</h3>
            <p>Корзина и заказы</p>
            <span class="project-tag">Vue</span>
          </div>
          <div class="project-card">
            <div class="project-icon">📝</div>
            <h3>Blog</h3>
            <p>Markdown + SSG</p>
            <span class="project-tag">Next</span>
          </div>
          <div class="project-card">
            <div class="project-icon">🧩</div>
            <h3>Game</h3>
            <p>Мини-игра на JS</p>
            <span class="project-tag">Canvas</span>
          </div>
          <div class="project-card">
            <div class="project-icon">🤖</div>
            <h3>Chatbot</h3>
            <p>AI-помощник</p>
            <span class="project-tag">Python</span>
          </div>
        </div>
      </section>

      <div class="contact-block">
        <span class="label">📬 Контакты:</span>
        <div class="chips">
          <span>telegram</span>
          <span>github</span>
          <span>email</span>
        </div>
        <span class="status">online</span>
      </div>
    </main>
  </div>
</body>
</html>
